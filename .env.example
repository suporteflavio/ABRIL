# =============================================================================
# Election SaaS – Environment Variables Example
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE_URL="postgresql://election_user:election_password@localhost:5432/election_db"

# --- Security ----------------------------------------------------------------
JWT_SECRET="your_super_secret_jwt_key_at_least_32_characters_long"
JWT_EXPIRES_IN="7d"

# --- Application -------------------------------------------------------------
PORT="3001"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- Telegram Bot (optional) -------------------------------------------------
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"

# --- Email (optional) --------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# --- Railway (production only) -----------------------------------------------
# RAILWAY_TOKEN is set in Railway/GitHub Secrets – never put it here
