# Application
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://abril_user:abril_password@localhost:5432/abril_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# OpenAI (optional)
OPENAI_API_KEY=

# Next.js public vars
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
